{
  "name": "@highlight-reviews/overlay",
  "version": "0.1.0",
  "description": "Stakeholder preview annotation overlay for Contentful projects",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:iife",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --target=es2017 --outfile=dist/index.mjs && tsc --emitDeclarationOnly --declaration --outDir dist",
    "build:iife": "esbuild src/overlay.ts --bundle --format=iife --global-name=HighlightReviews --target=es2017 --outfile=dist/overlay.iife.js",
    "dev": "npm run build:iife -- --watch"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "4.9.5"
  }
}
